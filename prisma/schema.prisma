datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

/**
 * ---------- Core tables ----------
 */

model Table {
  id       Int    @id @default(autoincrement())
  name     String
  capacity Int
  status   String // available | occupied | reserved

  orders Order[]
}

model Order {
  id          String @id @default(uuid())
  orderNumber Int    @default(autoincrement())

  tableId    Int?
  table      Table?   @relation(fields: [tableId], references: [id])
  customerId String?
  customer   Profile? @relation(fields: [customerId], references: [id])

  items OrderItem[]

  total  Int
  status String // Preparing | Ready | Paid
  paymentMethod String?

  createdAt DateTime  @default(now())
  paidAt    DateTime?
}

model OrderItem {
  id Int @id @default(autoincrement())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  menuItemId Int
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  quantity Int

  addOns Json? // { roti: 1, curry: -1 }
}

/**
 * ---------- Menu ----------
 */

model MenuItem {
  id Int @id @default(autoincrement())

  name     String
  category String
  price    Int
  image    String?

  enabled Boolean @default(true)

  orders OrderItem[]
}

/**
 * ---------- Grocery ----------
 */

model GroceryItem {
  id Int @id @default(autoincrement())

  name     String
  quantity Float
  unit     String

  purchased Boolean @default(false)
}

/**
 * ---------- Store (optional) ----------
 */

model StoreProduct {
  id String @id

  name     String
  category String
  price    Int
  stock    Int
  image    String?
}

model Profile {
  id          String   @id @default(uuid())
  email       String   @unique // Treated as unique username/email for auth
  password    String?
  role        String
  displayName String?
  phone       String?
  address     String?
  avatar      String?
  createdAt   DateTime @default(now())

  orders Order[]
}
